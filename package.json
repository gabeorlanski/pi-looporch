{
  "name": "pi-workflow",
  "version": "0.1.0",
  "description": "Workflow orchestration extension for pi.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "workflow",
    "agents",
    "orchestration"
  ],
  "files": [
    "extensions/",
    "src/",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/workflow.ts"
    ]
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "loadcheck": "pi --no-extensions -e ./extensions/workflow.ts --list-models __pi_workflow_load_check__",
    "docs:check": "tsx scripts/check-doc-contracts.ts",
    "docs:check:staged": "tsx scripts/check-doc-contracts.ts --staged",
    "check": "npm run lint && npm run format:check && npm run docs:check && npm run typecheck && npm test && npm run loadcheck",
    "precommit": "lint-staged && npm run docs:check:staged",
    "prepare": "husky",
    "dev": "pi -e ./extensions/workflow.ts",
    "pack:dry": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabeorlanski/pi-looporch.git"
  },
  "license": "MIT",
  "dependencies": {
    "typebox": "^1.2.8",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md}": [
      "prettier --write"
    ]
  }
}
