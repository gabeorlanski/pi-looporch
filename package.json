{
  "name": "pi-workflow",
  "version": "0.1.0",
  "description": "Workflow orchestration extension for pi.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "workflow",
    "agents",
    "orchestration"
  ],
  "files": [
    "extensions/",
    "src/",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/workflow.ts"
    ]
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "loadcheck": "pi --no-extensions -e ./extensions/workflow.ts --list-models __pi_workflow_load_check__",
    "check": "npm run lint && npm run typecheck && npm test && npm run loadcheck",
    "dev": "pi -e ./extensions/workflow.ts",
    "pack:dry": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@earendil-works/pi-tui": "^0.79.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabeorlanski/pi-looporch.git"
  },
  "license": "MIT",
  "dependencies": {
    "typebox": "^1.2.8"
  }
}
